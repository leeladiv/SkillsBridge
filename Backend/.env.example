# Required in production
JWT_SECRET=your-secret-key-change-in-production

# Admin login (used by npm run db:seed – never commit real values)
# Set these to create the admin user; leave unset to skip admin creation
ADMIN_EMAIL=student@test.com
ADMIN_PASSWORD=password123

# Optional
PORT=3000
NODE_ENV=development
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10
FRONTEND_ORIGIN=http://localhost:5173

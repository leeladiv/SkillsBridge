# Server
PORT=3000
NODE_ENV=development

# Auth (required in production)
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=7d
BCRYPT_ROUNDS=10

# Frontend (CORS and email verification links)
FRONTEND_ORIGIN=http://localhost:5173
FRONTEND_URL=http://localhost:5173

# Database (optional; defaults to Backend/data/dev.db)
# SQLITE_DIR=./data
# SQLITE_PATH=./data/dev.db

# SMTP for verification emails (optional; without these, verification link is returned in API response)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com
# SMTP_SECURE=false
